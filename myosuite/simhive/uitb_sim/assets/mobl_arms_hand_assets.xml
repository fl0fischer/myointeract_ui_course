<mujoco model="MoBL Arms Hand Model">
  <compiler angle="radian" boundmass="0.001" boundinertia="0.001"/>

  <size njmax="1000" nconmax="400" nuser_jnt="1"/>

  <visual>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <default>
    <joint stiffness="2" limited="true" armature="0.1" damping="0.5"/>
    <geom contype="0" conaffinity="0" margin="0.001" rgba="0.8 0.6 0.4 1"/>
    <site size="0.001 0.005 0.005" rgba="0.5 0.5 0.5 0"/>
    <!-- <mesh maxhullvert="64"/> -->

    <tendon rgba="0.95 0.3 0.3 1"/>
    <general ctrllimited="true" ctrlrange="0 1" dyntype="muscle" dynprm="0.01 0.04 0 0 0 0 0 0 0 0" gaintype="muscle" biastype="muscle" gainprm="0.75 1.05 -1 2000 0.5 1.6 1.5 1.3 1.2" biasprm="0.75 1.05 -1 2000 0.5 1.6 1.5 1.3 1.2"/>
    <default class="arm_skin">
        <geom type="capsule" contype="0" conaffinity="0" condim="3" rgba="0.8 0.7 .5 .1" margin="0.001" material="MatSkin"/>
    </default>
    <default class="hand_skin">
        <geom type="capsule" contype="1" conaffinity="0" condim="3" rgba="0.8 0.7 .5 .1" margin="0.001" material="MatSkin"/>
    </default>

    <default class="wrap">
        <geom group="3" rgba="0.19 0.83 0.78 0.2"/>
    </default>
    <default class="marker">
          <site rgba="1 0.1 0.5 0.5" size="0.001" group="4"/>
    </default>
    <default class="forearm_muscle">
        <muscle ctrllimited="true" ctrlrange="0 1" />
        <tendon rgba="0.95 0.3 0.3 41" width="0.002"/>
    </default>
    <default class="wrist">
        <joint limited="true" damping=".05" armature="1e-4" stiffness="0"/>
        <geom margin="0.001" rgba="0.8 0.8 0.8 1" contype="0" conaffinity="0"/>
        <site size="0.0025" group="2"/>
        <tendon rgba="0.95 0.3 0.3 41" width="0.002"/>
    </default>
    <default class="fingers">
        <joint limited="true" damping=".05" armature="1e-4" stiffness="0"/>
        <geom margin="0.001" rgba="0.8 0.8 0.8 1" contype="0" conaffinity="0"/>
        <site size="0.0025" group="2"/>
    </default>
  </default>

