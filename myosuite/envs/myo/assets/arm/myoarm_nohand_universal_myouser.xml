<mujoco model="MyoArm model without hand muscles for mid-air interaction tasks">
    <include file="../../../../simhive/myo_sim/arm/assets/myoarm_nohand_assets.xml"/>
    <!-- <include file="../../../../simhive/myo_sim/scene/myosuite_scene.xml"/> -->
    <compiler meshdir='../../../../simhive/myo_sim/' texturedir='../../../../simhive/myo_sim/'/>

    <asset>
        <!-- pick a body mesh below -->
        <!-- <mesh file="../../../../simhive/myo_sim/meshes/human_lowpoly_norighthand.stl" name="human_body"/> -->
        <mesh file="meshes/human_lowpoly_nohand.stl" name="human_body"/>
        <mesh file="../uitb_sim/assets/basic_eye_2.stl" scale="0.05 0.05 0.05" name="eye"/>
    </asset>

    <worldbody>
        <!-- <geom name="body" type="mesh" mesh="human_body" euler="0 0 3.14" contype="0" conaffinity="0"/> -->
        <body name="full_body" pos="-0.01913405 -0.03180473 1.00001133" euler="0 0 1.57">
            <include file="../../../../simhive/myo_sim/arm/assets/myoarm_body.xml"/>
        </body>

        <light name="scene_light" directional="true" castshadow="false" cutoff="4" exponent="20" diffuse="1 1 1" specular="0 0 0" pos="0.5 0.5 3.0"/>

        <body name="fixed-eye" pos="0 0 1.2" quat="0.583833 0.399104 -0.399421 -0.583368">
          <geom name="fixed-eye" quat="0.7106 0.25537 0.616985 0.221728" type="mesh" rgba="1 1 1 0" mesh="eye"/>
          <camera name="fixed-eye" pos="0 0 0" fovy="120"/>
        </body>
        <body name='side_camera' pos="0.25 -0.27 1.0" euler="1.5708 0 0">
          <camera name='side_camera' pos="0 0 1.2" fovy="70"/>
        </body>
        <body name='head_on_camera' pos="1.5 0.0 1.0" euler="1.5708 1.5708 0.0">
          <camera name='head_on_camera' pos="0 0 12" fovy="10"/>
        </body>
    </worldbody>
</mujoco>
